{
  "manifest_version": 3,
  "name": "New Tab Calendar",
  "description": "Replaces new tab with time, date, and upcoming Google Calendar events.",
  "key": "",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["identity", "storage"],
  "oauth2": {
    "client_id": "680388862326-tg94r9nmcl8m5gjk20fl6hchink2j0nh.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/calendar.readonly"]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://www.googleapis.com https://oauth2.googleapis.com"
  },
  "host_permissions": ["https://www.googleapis.com/*"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  }
}
